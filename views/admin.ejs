<!DOCTYPE html>
<html>
<head><title>Admin Panel - VaidyaVaani</title><link rel="stylesheet" href="/css/style.css"></head>
<body>
<h2>Admin Dashboard</h2>
<h3>All Users</h3>
<ul>
<% users.forEach(user => { %>
  <li><%= user.email %> — Role: <%= user.role %></li>
<% }) %>
</ul>
<h3>All Uploaded Descriptions</h3>
<ul>
<% files.forEach(file => { %>
  <li><%= file.originalname %> — Uploaded by <%= file.user.email %> on <%= file.createdAt.toDateString() %></li>
<% }) %>
</ul>
<a href="/logout">Logout</a>
</body></html>